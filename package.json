{
  "name": "@near-kit-tool-box/root",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '@near-kit-tool-box/*' build",
    "build:web": "bun run --filter '@near-kit-tool-box/web' build",
    "build:env": "bun run --filter '@near-kit-tool-box/env' build",
    "build:fun": "bun run --filter '@near-kit-tool-box/fun' build",
    "version:sync": "bun run scripts/version-sync.ts",
    "version:dry-run": "bun run scripts/version-sync.ts --dry-run",
    "publish:all": "bun run build && for pkg in packages/env packages/fun packages/web; do echo \"\\n📦 Publishing $pkg...\"; cd \"$pkg\" && bun publish --access public && cd ../..; done"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
